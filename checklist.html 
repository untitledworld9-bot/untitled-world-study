<!DOCTYPE html>
<html>
<head>

<meta name="viewport" content="width=device-width, initial-scale=1">

<title>Checklist | Untitled World</title>

<style>

body{
margin:0;
font-family:Outfit, sans-serif;
background:linear-gradient(135deg,#0f2027,#203a43,#2c5364);
color:white;
}

.app{

max-width:420px;
margin:auto;
padding:20px;

}

header{

display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:20px;

}

.addBtn{

background:#00ff88;
border:none;
padding:10px 14px;
border-radius:10px;
font-weight:bold;
cursor:pointer;
/* ADDED: Smooth hover and tap animations */
transition: transform 0.2s ease, background 0.2s ease;

}

/* ADDED: Hover and active states for Add Button */
.addBtn:hover {
transform: scale(1.1);
background: #00e67a;
}

.addBtn:active {
transform: scale(0.95);
}

.task{

display:flex;
align-items:center;
justify-content:space-between;

background:rgba(255,255,255,.07);
padding:14px;
border-radius:14px;

margin-bottom:12px;

backdrop-filter:blur(12px);

/* ADDED: Entrance animation and hover transitions */
opacity: 0; 
transform: translateY(15px);
animation: slideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.3s ease;

}

/* ADDED: Task hover effect */
.task:hover {
transform: translateY(-2px);
box-shadow: 0 4px 15px rgba(0,0,0,0.15);
}

/* ADDED: Slide up keyframe animation */
@keyframes slideUp {
to {
    opacity: 1;
    transform: translateY(0);
}
}

.task.done{

opacity:.5;
text-decoration:line-through;

}

.task span{

flex:1;
margin-left:10px;
/* ADDED: Smooth transition for strike-through */
transition: color 0.3s ease;

}

.delete{

background:none;
border:none;
color:#ff4d4d;
font-size:18px;
cursor:pointer;
/* ADDED: Delete button animations */
transition: transform 0.2s ease, color 0.2s ease;

}

/* ADDED: Hover state for Delete Button */
.delete:hover {
transform: scale(1.2);
color: #ff1a1a;
}

/* ADDED: Empty state text styling */
.empty-state {
text-align: center;
color: rgba(255, 255, 255, 0.5);
margin-top: 40px;
font-size: 0.95em;
animation: slideUp 0.4s ease forwards;
}

</style>

</head>

<body>

<div class="app">

<header>

<h2>Today's Checklist</h2>

<button class="addBtn" onclick="addTask()">＋</button>

</header>

<div id="taskList"></div>

</div>

<script src="checklist.js" type="module"></script>

</body>

</html>
